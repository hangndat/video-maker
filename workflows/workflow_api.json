{
  "1": {
    "class_type": "DownloadAndLoadLivePortraitModels",
    "inputs": {
      "precision": "auto",
      "mode": "human"
    }
  },
  "2": {
    "class_type": "LivePortraitLoadFaceAlignmentCropper",
