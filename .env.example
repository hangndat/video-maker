# Copy thành .env và điền key (OpenAI / ElevenLabs khi dùng).
# Preset chính: DATA_ROOT/profiles/{RENDER_PROFILE_ID}.json — xem docs/pipeline.md §2.

PORT=3000
DATA_ROOT=./shared_data

# Admin UI + /admin/api/* — bắt buộc để bật /admin (static sau npm run admin:build)
# ADMIN_API_TOKEN=

# --- Render preset (file-first) ---
# Default profile loads DATA_ROOT/profiles/{RENDER_PROFILE_ID}.json
RENDER_PROFILE_ID=cinematic_mystery
# DEFAULT_RENDER_PROFILE=cinematic_mystery

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
OPENAI_TEMPERATURE=0.75
CHARS_PER_SECOND=14

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# Optional overrides for API voice_settings:
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY_BOOST=0.75
# ELEVENLABS_STYLE=0.3

# SEGMENT_VIDEO_MODE=freeze_last  # or loop — per-segment default from preset
# VIDEO_OUTPUT_FPS=30
# DEFAULT_BROLL_PLACEHOLDER=assets/broll/placeholder.mp4

# PIPELINE_LOG=1

# --- E2E (npm run test:e2e) — cần ffmpeg/ffprobe trên PATH; xem README § Test E2E ---
# E2E_HTTP=1                    # trên CI: bật để chạy suite from-video (không cần secret)
# LANGFUSE_TRACING_ENABLED=0    # gợi ý khi spawn app trong E2E để tắt flush OTEL
# E2E_BASE_URL=http://127.0.0.1:3000
# E2E_DATA_ROOT=./shared_data   # khi dùng E2E_BASE_URL: phải trùng DATA_ROOT của server
# E2E_PORT=3939

BGM_PATH=

TIKTOK_SAFE_BOTTOM_PCT=0.15
ASS_FONT_NAME=Arial
ASS_FONT_SIZE=72
ASS_PRIMARY_COLOR=
ASS_HIGHLIGHT_COLOR=
AUDIO_MIX_MODE=simple
BGM_VOLUME=0.2
BGM_FADE_OUT_SEC=2

# --- Smoke đa cảnh (scripts/smoke-multiscene.ts) ---
# SMOKE_MULTISCENE_JOB_ID=my-smoke-job
# SMOKE_MULTISCENE_N=12
# SMOKE_MULTISCENE_SCENE_SEC=5

# --- Langfuse ---
# LANGFUSE_BASE_URL=http://127.0.0.1:3030
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_TRACING_ENABLED=
# LANGFUSE_OTEL_EXPORT_MODE=immediate
# LANGFUSE_ELEVENLABS_USD_PER_1K_CHARS=
# LANGFUSE_LOG_TTS_TEXT=
