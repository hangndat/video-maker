PORT=3000
DATA_ROOT=./shared_data

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # tuỳ chọn: proxy / Azure-compatible endpoint
CHARS_PER_SECOND=14

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ComfyUI chạy ngoài app (trên macOS: native + Metal — xem docs/comfy-macos.md)
COMFY_HTTP_URL=http://127.0.0.1:8188
# COMFY_WS_URL=  # tuỳ chọn; để trống = suy ra từ COMFY_HTTP_URL
# Nếu cả ba để trống: app tự tìm ComfyUI tại ../ComfyUI (cạnh repo), ~/SideProject/ComfyUI, ~/ComfyUI
# COMFY_ROOT=/Users/you/ComfyUI
# Hoặc chỉ định trực tiếp (khuyến nghị nếu cài ở chỗ khác):
# COMFY_INPUT_DIR=/Users/you/ComfyUI/input
# COMFY_OUTPUT_DIR=/Users/you/ComfyUI/output
# Phải trùng thư mục Comfy server thật sự dùng (mặc định …/ComfyUI/input). Chỉ trỏ vào shared_data/comfy_input
# nếu bạn đã chạy Comfy với: python main.py --input-directory /path/to/shared_data/comfy_input …
COMFY_ROOT=
COMFY_INPUT_DIR=
COMFY_OUTPUT_DIR=
COMFY_OOM_MAX_RETRIES=3
COMFY_OOM_RETRY_SEC=30
COMFY_WS_TIMEOUT_MS=3600000

# LivePortrait (Kijai): video lái (mp4) — copy vào Comfy input dưới tên {jobId}_driving.mp4.
# Không set COMFY_DRIVING_VIDEO: chọn file từ DATA_ROOT/assets/driving/ theo emotion CẢNH ĐẦU (laugh, angry, …) — xem docs/pipeline.md §3.
# Fallback nếu thiếu file trong driving/: DATA_ROOT/assets/driving_reference.mp4
# COMFY_DRIVING_VIDEO=/absolute/path/to/force-single-clip.mp4

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 1 = bỏ Comfy (video placeholder); dùng khi chưa cài Comfy hoặc chỉ test voice/ffmpeg
SKIP_COMFY=0

# Log orchestration ra stderr: script OpenAI vs preset, hook Comfy, TTS từng cảnh, FFmpeg motion/scene
# PIPELINE_LOG=1

# --- Smoke đa cảnh ($0, scripts/smoke-multiscene.ts) — thường chỉ set qua shell ---
# Không set JOB_ID → thư mục = smoke-multiscene-{N}x{SEC}s (vd. smoke-multiscene-12x5s)
# SMOKE_MULTISCENE_JOB_ID=my-smoke-job
# SMOKE_MULTISCENE_N=12
# SMOKE_MULTISCENE_SCENE_SEC=5
BGM_PATH=

TIKTOK_SAFE_BOTTOM_PCT=0.15
ASS_FONT_NAME=Arial
ASS_FONT_SIZE=72
AUDIO_MIX_MODE=simple
BGM_VOLUME=0.2
BGM_FADE_OUT_SEC=2

# --- Langfuse (tracing / OTEL). Requires Node >= 20. ---
# Seed Docker Langfuse: npm run langfuse:env  (hoặc bash scripts/gen-langfuse-seed.sh > .env.langfuse)
# LANGFUSE_BASE_URL=http://127.0.0.1:3030
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_TRACING_ENABLED=  # set 0 to force off
# LANGFUSE_OTEL_EXPORT_MODE=immediate  # tuỳ chọn: gửi span nhanh khi debug Langfuse
# LANGFUSE_ELEVENLABS_USD_PER_1K_CHARS=   # USD / 1000 ký tự input — ước lượng cost TTS trên Langfuse (đối chiếu pricing ElevenLabs)
# LANGFUSE_LOG_TTS_TEXT=    # set 1 to send full TTS strings (default: only char counts)

