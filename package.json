{
  "name": "video-maker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "admin": "npm run dev --prefix admin",
    "admin:build": "npm run build --prefix admin",
    "dev": "tsx watch src/app.ts",
    "build": "npm run admin:build && tsc",
    "test": "tsx --test \"src/api/*.test.ts\" \"src/shared/*.test.ts\"",
    "test:e2e": "tsx --test src/e2e/from-video.e2e.test.ts src/e2e/full-render.e2e.test.ts",
    "start": "node dist/src/app.js",
    "smoke:video": "tsx scripts/smoke-video.ts",
    "smoke:multiscene": "tsx scripts/smoke-multiscene.ts",
    "smoke:chain": "tsx scripts/smoke-chain.ts",
    "phase3:preset": "tsx scripts/phase3-render-preset.ts",
    "render:consistency": "tsx scripts/full-consistency-render.ts",
    "render:from-video": "tsx scripts/from-video.ts",
    "langfuse:seed": "bash scripts/gen-langfuse-seed.sh",
    "langfuse:env": "node scripts/write-langfuse-env.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langfuse/openai": "^5.0.1",
    "@langfuse/otel": "^5.0.1",
    "@langfuse/tracing": "^5.0.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "http-proxy-middleware": "^3.0.5",
    "openai": "^4.76.0",
    "p-queue": "^8.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
