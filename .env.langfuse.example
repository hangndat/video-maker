# Khuyến nghị — sinh đủ secrets + LANGFUSE_INIT_* (không redirect npm ra file):
#   npm run langfuse:env
#   hoặc: bash scripts/gen-langfuse-seed.sh > .env.langfuse
#
# Chạy stack:
#   docker compose -f docker-compose.langfuse.yml --env-file .env.langfuse up -d
#
# UI: http://localhost:3030  |  video-maker: http://localhost:3000
#
# Tracing: trong .env app đặt LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY
#          = LANGFUSE_INIT_PROJECT_PUBLIC_KEY / LANGFUSE_INIT_PROJECT_SECRET_KEY
#          và LANGFUSE_BASE_URL=http://127.0.0.1:3030
#
# Headless init: https://langfuse.com/self-hosting/administration/headless-initialization
# Không thêm dấu ngoặc quanh giá trị trong file env cho Docker Compose.

NEXTAUTH_URL=http://localhost:3030
NEXTAUTH_SECRET=CHANGEME
SALT=CHANGEME
ENCRYPTION_KEY=CHANGEME

POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/postgres

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=CHANGEME
REDIS_AUTH=CHANGEME
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGEME

LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=minio
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}

LANGFUSE_INIT_ORG_ID=ma-chu-local
LANGFUSE_INIT_ORG_NAME=Ma Chu Local
LANGFUSE_INIT_PROJECT_ID=video-maker
LANGFUSE_INIT_PROJECT_NAME=Ma Chu Video Maker
LANGFUSE_INIT_USER_EMAIL=admin@localhost.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=CHANGEME
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf_pk_CHANGEME
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf_sk_CHANGEME
